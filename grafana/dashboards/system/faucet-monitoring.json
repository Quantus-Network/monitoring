{
  "title": "Faucet Metrics",
  "uid": "faucet-metrics",
  "tags": ["faucet", "support"],
  "timezone": "browser",
  "schemaVersion": 41,
  "refresh": "30s",
  "editable": true,
  "panels": [
    {
      "type": "row",
      "title": "Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Faucet Up",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "faucet_up{job=\"support-faucet\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Chain Connected",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "faucet_chain_connected{job=\"support-faucet\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DISCONNECTED", "color": "red" }, "1": { "text": "CONNECTED", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "time() - faucet_start_time_seconds{job=\"support-faucet\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Twitter",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "faucet_twitter_enabled{job=\"support-faucet\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFF", "color": "dark-red" }, "1": { "text": "ON", "color": "dark-green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "dark-red" }, { "value": 1, "color": "dark-green" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Telegram",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "faucet_telegram_enabled{job=\"support-faucet\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFF", "color": "dark-red" }, "1": { "text": "ON", "color": "dark-green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "dark-red" }, { "value": 1, "color": "dark-green" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Users",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "faucet_active_users{job=\"support-faucet\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Chain Reconnects",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "faucet_chain_reconnects_total{job=\"support-faucet\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "value": 1, "color": "orange" }, { "value": 5, "color": "red" }] }
        }
      }
    },

    {
      "type": "row",
      "title": "Requests & Transfers",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 6 },
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "faucet_total_requests{job=\"support-faucet\"}", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "type": "stat",
      "title": "Successful",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 6 },
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "faucet_successful_transfers{job=\"support-faucet\"}", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "type": "stat",
      "title": "Failed",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 6 },
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "faucet_failed_transfers{job=\"support-faucet\"}", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "value": 1, "color": "red" }] } } }
    },
    {
      "type": "stat",
      "title": "Success Rate",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 6 },
      "id": 13,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(faucet_successful_transfers{job=\"support-faucet\"} / clamp_min(faucet_total_requests{job=\"support-faucet\"}, 1)) * 100", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1, "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "value": 80, "color": "yellow" }, { "value": 95, "color": "green" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Rate Limited",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 6 },
      "id": 14,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "faucet_rate_limited_requests{job=\"support-faucet\"}", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "value": 1, "color": "orange" }] } } }
    },
    {
      "type": "stat",
      "title": "Max Balance Rejected",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 6 },
      "id": 15,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "faucet_max_balance_rejections{job=\"support-faucet\"}", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "value": 1, "color": "yellow" }] } } }
    },

    {
      "type": "row",
      "title": "Balance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 102,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Faucet Account Balance",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 12 },
      "id": 20,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "faucet_account_balance{job=\"support-faucet\"} / 1e12", "legendFormat": "Balance", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value",
        "text": { "titleSize": 16, "valueSize": 40 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "displayName": "QU",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "value": 10000, "color": "yellow" }, { "value": 50000, "color": "green" }] }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Balance Over Time",
      "gridPos": { "h": 7, "w": 16, "x": 8, "y": 12 },
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "faucet_account_balance{job=\"support-faucet\"} / 1e12", "legendFormat": "Balance (QU)", "refId": "A" }],
      "options": {
        "legend": { "calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme",
            "showPoints": "never", "spanNulls": false,
            "axisBorderShow": false, "axisLabel": "QU", "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "value": 10000, "color": "transparent" }] }
        }
      }
    },

    {
      "type": "row",
      "title": "Platform Breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 103,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Platform",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 30,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(faucet_platform_requests_total{job=\"support-faucet\"}[5m]) * 60", "legendFormat": "{{platform}} requests", "refId": "A" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm", "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20,
            "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "axisBorderShow": false, "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Transfers by Platform",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(faucet_platform_transfers_ok_total{job=\"support-faucet\"}[5m]) * 60", "legendFormat": "{{platform}} OK", "refId": "A" },
        { "expr": "rate(faucet_platform_transfers_failed_total{job=\"support-faucet\"}[5m]) * 60", "legendFormat": "{{platform}} failed", "refId": "B" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm", "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20,
            "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "axisBorderShow": false, "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          }
        }
      }
    },

    {
      "type": "row",
      "title": "Transfer Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 104,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Transfer Duration (avg)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 29 },
      "id": 40,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(faucet_transfer_duration_seconds_sum{job=\"support-faucet\"}[5m]) / rate(faucet_transfer_duration_seconds_count{job=\"support-faucet\"}[5m])", "legendFormat": "avg duration", "refId": "A" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10,
            "showPoints": "auto", "spanNulls": false,
            "axisBorderShow": false, "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "value": 30, "color": "yellow" }, { "value": 60, "color": "red" }] }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Queue Wait Time (avg)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 29 },
      "id": 41,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(faucet_transfer_queue_wait_seconds_sum{job=\"support-faucet\"}[5m]) / rate(faucet_transfer_queue_wait_seconds_count{job=\"support-faucet\"}[5m])", "legendFormat": "avg wait", "refId": "A" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 3,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10,
            "showPoints": "auto", "spanNulls": false,
            "axisBorderShow": false, "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Pending Transfers & Retries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 29 },
      "id": 42,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "faucet_pending_transfers{job=\"support-faucet\"}", "legendFormat": "Pending in queue", "refId": "A" },
        { "expr": "faucet_transfer_retries_total{job=\"support-faucet\"}", "legendFormat": "Transfer retries (total)", "refId": "B" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10,
            "showPoints": "auto", "spanNulls": false,
            "axisBorderShow": false, "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          }
        }
      }
    },

    {
      "type": "row",
      "title": "Twitter API Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "id": 105,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Time Since Last Successful Poll",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 38 },
      "id": 50,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "time() - faucet_twitter_api_last_success_timestamp_seconds{job=\"support-faucet\"}", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "value": 300, "color": "yellow" }, { "value": 600, "color": "red" }] }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Twitter API Request Rate",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 38 },
      "id": 51,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(faucet_twitter_api_requests_total{job=\"support-faucet\"}[5m]) * 60", "legendFormat": "requests/min", "refId": "A" },
        { "expr": "rate(faucet_twitter_api_retries_total{job=\"support-faucet\"}[5m]) * 60", "legendFormat": "retries/min", "refId": "B" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm", "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10,
            "showPoints": "never", "spanNulls": false,
            "axisBorderShow": false, "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Twitter API Errors by Type",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 38 },
      "id": 52,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(faucet_twitter_api_errors_total{job=\"support-faucet\"}[5m]) * 60", "legendFormat": "{{error_type}}", "refId": "A" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm", "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10,
            "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "axisBorderShow": false, "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          }
        }
      }
