          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "substrate_block_height{status=\"best\",chain=\"$chain\"}",
          "legendFormat": "Best Block - {{instance}}",
          "refId": "A"
        },
        {
          "expr": "substrate_block_height{status=\"finalized\",chain=\"$chain\"}",
          "legendFormat": "Finalized Block - {{instance}}",
          "refId": "B"
        }
      ],
