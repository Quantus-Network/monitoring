  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Estimated network hashrate, two methods overlaid:\n- Duration-based: difficulty / last_block_duration (uses on-chain observed block time in ms).\n- Block-rate based: difficulty * d(chain_height)/dt over a 10m window (uses empirically observed block production rate).\nBoth assume QPOW difficulty represents the expected number of hash attempts per block. They should converge over long enough windows; short-term divergence is informative (e.g. per-block duration noise, or Poisson noise on the block-rate side).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          },
          "unit": "MH/s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "avg by (chain) (qpow_metrics{data_group=\"difficulty\", chain=\"$chain\"}) / clamp_min(avg by (chain) (qpow_metrics{data_group=\"last_block_duration\", chain=\"$chain\"}) / 1000, 0.001) / 1e6",
          "legendFormat": "Duration-based",
          "refId": "A"
        },
        {
          "expr": "avg by (chain) (qpow_metrics{data_group=\"difficulty\", chain=\"$chain\"}) * clamp_min(deriv(max by (chain) (qpow_metrics{data_group=\"chain_height\", chain=\"$chain\"})[10m:]), 0) / 1e6",
          "legendFormat": "Block-rate (10m)",
          "refId": "B"
        }
      ],
      "title": "Estimated Network Hashrate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Average estimated network hashrate over the dashboard's selected time range. Two methods shown: duration-based (uses on-chain last_block_duration) and block-rate-based (uses observed chain_height growth). Both should converge over long enough windows.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          },
          "unit": "MH/s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "vertical",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "avg_over_time((avg by (chain) (qpow_metrics{data_group=\"difficulty\", chain=\"$chain\"}) / clamp_min(avg by (chain) (qpow_metrics{data_group=\"last_block_duration\", chain=\"$chain\"}) / 1000, 0.001) / 1e6)[$__range:])",
          "legendFormat": "Duration:",
          "refId": "A"
        },
        {
          "expr": "avg_over_time((avg by (chain) (qpow_metrics{data_group=\"difficulty\", chain=\"$chain\"}) * clamp_min(deriv(max by (chain) (qpow_metrics{data_group=\"chain_height\", chain=\"$chain\"})[10m:]), 0) / 1e6)[$__range:])",
          "legendFormat": "Block:",
          "refId": "B"
        }
      ],
      "title": "Avg Network Hashrate (range)",
      "type": "stat"
    },
