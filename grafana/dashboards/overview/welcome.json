  "panels": [
    {
      "type": "text",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "mode": "markdown",
        "content": "# Quantus Network Overview\n\nReal-time monitoring across **Planck**, **Heisenberg**, and **Dirac**. Use the **Chains** folder dashboards with the chain selector for detailed views.\n\n[quantus.com](https://www.quantus.com/)"
      }
    },
    {
      "type": "stat",
      "title": "Planck - Chain Height",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 3
      },
      "id": 50,
      "targets": [
        {
          "expr": "max(qpow_metrics{data_group=\"chain_height\", chain=\"planck\"})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {
          "titleSize": 16,
          "valueSize": 32
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#FF6B35"
          }
        }
      }
    },
